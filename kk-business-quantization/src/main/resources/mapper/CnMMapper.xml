<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kk.business.quantization.dao.mapper.CnMMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kk.business.quantization.dao.entity.CnM">
        <id column="month" property="month" />
        <result column="m0" property="m0" />
        <result column="m0_yoy" property="m0Yoy" />
        <result column="m0_mom" property="m0Mom" />
        <result column="m1" property="m1" />
        <result column="m1_yoy" property="m1Yoy" />
        <result column="m1_mom" property="m1Mom" />
        <result column="m2" property="m2" />
        <result column="m2_yoy" property="m2Yoy" />
        <result column="m2_mom" property="m2Mom" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="BaseColumnList">
        month as 'month',
        m0 as 'm0',
        m0_yoy as 'm0Yoy',
        m0_mom as 'm0Mom',
        m1 as 'm1',
        m1_yoy as 'm1Yoy',
        m1_mom as 'm1Mom',
        m2 as 'm2',
        m2_yoy as 'm2Yoy',
        m2_mom as 'm2Mom'

    </sql>
    <!-- 通用查询条件 -->
    <sql id="BaseWhere">
        <trim prefix="where" prefixOverrides="and | or">
           <if test="cnMListReqVo.month != null and cnMListReqVo.month != ''">
               and month = #{cnMListReqVo.month}
           </if>
            <if test="cnMListReqVo.monthStart != null and cnMListReqVo.monthStart != ''">
                and month >= #{cnMListReqVo.monthStart}
            </if>
            <if test="cnMListReqVo.monthEnd != null and cnMListReqVo.monthEnd != ''">
                and month &lt;= #{cnMListReqVo.monthEnd}
            </if>
           <if test="cnMListReqVo.m0 != null and cnMListReqVo.m0 != ''">
               and m0 = #{cnMListReqVo.m0}
           </if>
           <if test="cnMListReqVo.m0Yoy != null and cnMListReqVo.m0Yoy != ''">
               and m0_yoy = #{cnMListReqVo.m0Yoy}
           </if>
           <if test="cnMListReqVo.m0Mom != null and cnMListReqVo.m0Mom != ''">
               and m0_mom = #{cnMListReqVo.m0Mom}
           </if>
           <if test="cnMListReqVo.m1 != null and cnMListReqVo.m1 != ''">
               and m1 = #{cnMListReqVo.m1}
           </if>
           <if test="cnMListReqVo.m1Yoy != null and cnMListReqVo.m1Yoy != ''">
               and m1_yoy = #{cnMListReqVo.m1Yoy}
           </if>
           <if test="cnMListReqVo.m1Mom != null and cnMListReqVo.m1Mom != ''">
               and m1_mom = #{cnMListReqVo.m1Mom}
           </if>
           <if test="cnMListReqVo.m2 != null and cnMListReqVo.m2 != ''">
               and m2 = #{cnMListReqVo.m2}
           </if>
           <if test="cnMListReqVo.m2Yoy != null and cnMListReqVo.m2Yoy != ''">
               and m2_yoy = #{cnMListReqVo.m2Yoy}
           </if>
           <if test="cnMListReqVo.m2Mom != null and cnMListReqVo.m2Mom != ''">
               and m2_mom = #{cnMListReqVo.m2Mom}
           </if>
        </trim>
    </sql>

    <!-- 分页查询 -->
    <select id="selectCnMPageList" resultType="com.kk.business.quantization.model.vobase.res.CnMListResVo">
        select <include refid="BaseColumnList"/>
        from cn_m
        <include refid="BaseWhere"/>

    </select>



</mapper>
