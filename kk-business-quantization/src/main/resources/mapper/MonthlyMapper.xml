<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kk.business.quantization.dao.mapper.MonthlyMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kk.business.quantization.dao.entity.Monthly">
        <id column="ts_code" property="tsCode" />
        <id column="trade_date" property="tradeDate" />
        <result column="open" property="open" />
        <result column="high" property="high" />
        <result column="low" property="low" />
        <result column="close" property="close" />
        <result column="pre_close" property="preClose" />
        <result column="change" property="change" />
        <result column="pct_chg" property="pctChg" />
        <result column="vol" property="vol" />
        <result column="amount" property="amount" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="BaseColumnList">
        ts_code as 'tsCode',
        trade_date as 'tradeDate',
        open as 'open',
        high as 'high',
        low as 'low',
        close as 'close',
        pre_close as 'preClose',
        change as 'change',
        pct_chg as 'pctChg',
        vol as 'vol',
        amount as 'amount'

    </sql>
    <!-- 通用查询条件 -->
    <sql id="BaseWhere">
        <trim prefix="where" prefixOverrides="and | or">
           <if test="monthlyListReqVo.tsCode != null and monthlyListReqVo.tsCode != ''">
               and ts_code = #{monthlyListVo.tsCode}
           </if>
           <if test="monthlyListReqVo.tradeDateStart != null and monthlyListReqVo.tradeDateStart != ''">
               and trade_date >= #{monthlyListVo.tradeDateStart}
           </if>
           <if test="monthlyListReqVo.tradeDateEnd != null and monthlyListReqVo.tradeDateEnd != ''">
               and trade_date &lt;= #{monthlyListVo.tradeDateEnd}
           </if>
           <if test="monthlyListReqVo.open != null and monthlyListReqVo.open != ''">
               and open = #{monthlyListVo.open}
           </if>
           <if test="monthlyListReqVo.high != null and monthlyListReqVo.high != ''">
               and high = #{monthlyListVo.high}
           </if>
           <if test="monthlyListReqVo.low != null and monthlyListReqVo.low != ''">
               and low = #{monthlyListVo.low}
           </if>
           <if test="monthlyListReqVo.close != null and monthlyListReqVo.close != ''">
               and close = #{monthlyListVo.close}
           </if>
           <if test="monthlyListReqVo.preClose != null and monthlyListReqVo.preClose != ''">
               and pre_close = #{monthlyListVo.preClose}
           </if>
           <if test="monthlyListReqVo.change != null and monthlyListReqVo.change != ''">
               and change = #{monthlyListVo.change}
           </if>
           <if test="monthlyListReqVo.pctChg != null and monthlyListReqVo.pctChg != ''">
               and pct_chg = #{monthlyListVo.pctChg}
           </if>
           <if test="monthlyListReqVo.vol != null and monthlyListReqVo.vol != ''">
               and vol = #{monthlyListVo.vol}
           </if>
           <if test="monthlyListReqVo.amount != null and monthlyListReqVo.amount != ''">
               and amount = #{monthlyListVo.amount}
           </if>
        </trim>
    </sql>

    <!-- 分页查询 -->
    <select id="selectMonthlyPageList" resultType="com.kk.business.quantization.model.vobase.res.MonthlyListResVo">
        select <include refid="BaseColumnList"/>
        from monthly
        <include refid="BaseWhere"/>

    </select>



</mapper>
