<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kk.business.quantization.dao.mapper.DailyTimeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kk.business.quantization.dao.entity.DailyTime">
        <id column="ts_code" property="tsCode" />
        <id column="trade_date" property="tradeDate" />
        <id column="trade_time" property="tradeTime" />
        <result column="open" property="open" />
        <result column="high" property="high" />
        <result column="low" property="low" />
        <result column="close" property="close" />
        <result column="pre_close" property="preClose" />
        <result column="change" property="change" />
        <result column="pct_chg" property="pctChg" />
        <result column="vol" property="vol" />
        <result column="amount" property="amount" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="BaseColumnList">
        ts_code as 'tsCode',
        trade_date as 'tradeDate',
        trade_time as 'tradeTime',
        open as 'open',
        high as 'high',
        low as 'low',
        close as 'close',
        pre_close as 'preClose',
        change as 'change',
        pct_chg as 'pctChg',
        vol as 'vol',
        amount as 'amount'

    </sql>
    <!-- 通用查询条件 -->
    <sql id="BaseWhere">
        <trim prefix="where" prefixOverrides="and | or">
           <if test="dailyTimeListReqVo.tsCode != null and dailyTimeListReqVo.tsCode != ''">
               and ts_code = #{dailyTimeListVo.tsCode}
           </if>
           <if test="dailyTimeListReqVo.tradeDateStart != null and dailyTimeListReqVo.tradeDateStart != ''">
               and trade_date >= #{dailyTimeListVo.tradeDateStart}
           </if>
           <if test="dailyTimeListReqVo.tradeDateEnd != null and dailyTimeListReqVo.tradeDateEnd != ''">
               and trade_date &lt;= #{dailyTimeListVo.tradeDateEnd}
           </if>
           <if test="dailyTimeListReqVo.tradeTime != null and dailyTimeListReqVo.tradeTime != ''">
               and trade_time = #{dailyTimeListVo.tradeTime}
           </if>
           <if test="dailyTimeListReqVo.open != null and dailyTimeListReqVo.open != ''">
               and open = #{dailyTimeListVo.open}
           </if>
           <if test="dailyTimeListReqVo.high != null and dailyTimeListReqVo.high != ''">
               and high = #{dailyTimeListVo.high}
           </if>
           <if test="dailyTimeListReqVo.low != null and dailyTimeListReqVo.low != ''">
               and low = #{dailyTimeListVo.low}
           </if>
           <if test="dailyTimeListReqVo.close != null and dailyTimeListReqVo.close != ''">
               and close = #{dailyTimeListVo.close}
           </if>
           <if test="dailyTimeListReqVo.preClose != null and dailyTimeListReqVo.preClose != ''">
               and pre_close = #{dailyTimeListVo.preClose}
           </if>
           <if test="dailyTimeListReqVo.change != null and dailyTimeListReqVo.change != ''">
               and change = #{dailyTimeListVo.change}
           </if>
           <if test="dailyTimeListReqVo.pctChg != null and dailyTimeListReqVo.pctChg != ''">
               and pct_chg = #{dailyTimeListVo.pctChg}
           </if>
           <if test="dailyTimeListReqVo.vol != null and dailyTimeListReqVo.vol != ''">
               and vol = #{dailyTimeListVo.vol}
           </if>
           <if test="dailyTimeListReqVo.amount != null and dailyTimeListReqVo.amount != ''">
               and amount = #{dailyTimeListVo.amount}
           </if>
        </trim>
    </sql>

    <!-- 分页查询 -->
    <select id="selectDailyTimePageList" resultType="com.kk.business.quantization.model.vobase.res.DailyTimeListResVo">
        select <include refid="BaseColumnList"/>
        from daily_time
        <include refid="BaseWhere"/>

    </select>



</mapper>
