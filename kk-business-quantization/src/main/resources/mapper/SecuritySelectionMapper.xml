<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kk.business.quantization.dao.mapper.SecuritySelectionMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kk.business.quantization.dao.entity.SecuritySelection">
        <id column="ts_code" property="tsCode" />
        <id column="trade_date" property="tradeDate" />
        <result column="select_type" property="selectType" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="BaseColumnList">
        ts_code as 'tsCode',
        trade_date as 'tradeDate',
        select_type as 'selectType'

    </sql>
    <!-- 通用查询条件 -->
    <sql id="BaseWhere">
        <trim prefix="where" prefixOverrides="and | or">
           <if test="securitySelectionListReqVo.tsCode != null and securitySelectionListReqVo.tsCode != ''">
               and ts_code = #{securitySelectionListReqVo.tsCode}
           </if>
           <if test="securitySelectionListReqVo.tradeDateStart != null and securitySelectionListReqVo.tradeDateStart != ''">
               and trade_date >= #{securitySelectionListReqVo.tradeDateStart}
           </if>
           <if test="securitySelectionListReqVo.tradeDateEnd != null and securitySelectionListReqVo.tradeDateEnd != ''">
               and trade_date &lt;= #{securitySelectionListReqVo.tradeDateEnd}
           </if>
           <if test="securitySelectionListReqVo.selectType != null and securitySelectionListReqVo.selectType != ''">
               and select_type = #{securitySelectionListReqVo.selectType}
           </if>
        </trim>
    </sql>

    <!-- 分页查询 -->
    <select id="selectSecuritySelectionPageList" resultType="com.kk.business.quantization.model.vobase.res.SecuritySelectionListResVo">
        select <include refid="BaseColumnList"/>
        from security_selection
        <include refid="BaseWhere"/>

    </select>



</mapper>
