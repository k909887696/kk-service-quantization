<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kk.business.quantization.dao.mapper.TradeCalMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kk.business.quantization.dao.entity.TradeCal">
        <id column="exchange" property="exchange" />
        <id column="cal_date" property="calDate" />
        <result column="is_open" property="isOpen" />
        <result column="pretrade_date" property="pretradeDate" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="BaseColumnList">
        exchange as 'exchange',
        cal_date as 'calDate',
        is_open as 'isOpen',
        pretrade_date as 'pretradeDate'

    </sql>
    <!-- 通用查询条件 -->
    <sql id="BaseWhere">
        <trim prefix="where" prefixOverrides="and | or">
           <if test="tradeCalListReqVo.exchange != null and tradeCalListReqVo.exchange != ''">
               and exchange = #{tradeCalListVo.exchange}
           </if>
           <if test="tradeCalListReqVo.calDateStart != null and tradeCalListReqVo.calDateStart != ''">
               and cal_date >= #{tradeCalListVo.calDateStart}
           </if>
           <if test="tradeCalListReqVo.calDateEnd != null and tradeCalListReqVo.calDateEnd != ''">
               and cal_date &lt;= #{tradeCalListVo.calDateEnd}
           </if>
           <if test="tradeCalListReqVo.isOpen != null and tradeCalListReqVo.isOpen != ''">
               and is_open = #{tradeCalListVo.isOpen}
           </if>
           <if test="tradeCalListReqVo.pretradeDateStart != null and tradeCalListReqVo.pretradeDateStart != ''">
               and pretrade_date >= #{tradeCalListVo.pretradeDateStart}
           </if>
           <if test="tradeCalListReqVo.pretradeDateEnd != null and tradeCalListReqVo.pretradeDateEnd != ''">
               and pretrade_date &lt;= #{tradeCalListVo.pretradeDateEnd}
           </if>
        </trim>
    </sql>

    <!-- 分页查询 -->
    <select id="selectTradeCalPageList" resultType="com.kk.business.quantization.model.vobase.res.TradeCalListResVo">
        select <include refid="BaseColumnList"/>
        from trade_cal
        <include refid="BaseWhere"/>

    </select>



</mapper>
